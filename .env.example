# ============================================================
# EventGear — Environment Variables
# Copy to .env.local for local development. Never commit .env.local
# ============================================================

# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# DynamoDB
DYNAMODB_TABLE_NAME=eventgear-dev
# For local development:
DYNAMODB_ENDPOINT=http://localhost:8000

# EventBridge
EVENTBRIDGE_BUS_NAME=eventgear-dev

# Bedrock
BEDROCK_AGENT_ID=XXXXXXXXXX
BEDROCK_AGENT_ALIAS_ID=XXXXXXXXXX
BEDROCK_KNOWLEDGE_BASE_ID=XXXXXXXXXX
BEDROCK_REGION=us-east-1

# API Gateway
API_BASE_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/v1

# Auth (Cognito or custom JWT)
JWT_SECRET=local-dev-secret-do-not-use-in-prod
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# S3
ASSETS_BUCKET=eventgear-assets-dev
FRONTEND_BUCKET=eventgear-web-dev

# CloudFront
CLOUDFRONT_DISTRIBUTION_ID=XXXXXXXXXXXXXX

# Feature Flags
FEATURE_AI_ASSISTANT=true
FEATURE_MAINTENANCE_SCHEDULER=false

# Environment
NODE_ENV=development
LOG_LEVEL=debug
