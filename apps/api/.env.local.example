# Local dev environment — used by: pnpm dev (apps/api)
# Copy to .env.local: cp .env.local.example .env.local

# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ── DynamoDB Local ─────────────────────────────────────────────────────────────
# Started automatically via: pnpm dev:setup (docker-compose up -d)
DYNAMODB_TABLE_NAME=eventgear-dev
DYNAMODB_ENDPOINT=http://localhost:8000

# ── AWS (fake values — SDK needs these even for local DynamoDB) ────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ── EventBridge (no-op locally — events are logged to console) ─────────────────
EVENTBRIDGE_BUS_NAME=eventgear-dev

# ── Auth (fake secret for local dev — never use in production) ─────────────────
JWT_SECRET=local-dev-secret-change-me-in-production
